  "scripts": {
    "dev": "vite",
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=4096 vite build",
    "preview": "vite preview --port 5050",
    "test": "npm run test:unit",
    "test:unit": "vitest --environment jsdom",
    "test:e2e": "playwright test",
    "test:e2e:dev": "cross-env BASE_URL=http://localhost:5173 NO_WEB_SERVER=true playwright test",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.vite-config.json --composite false",
    "typecheck:app": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint \"src/**/*.{ts,tsx,vue}\" \"vite.config.ts\"",
    "script:create:tool": "node scripts/create-tool.mjs",
    "script:create:ui": "hygen generator ui-component",
    "release": "node ./scripts/release.mjs"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "25.5.0"
    }
