{
  "extends": "@tsconfig/node18/tsconfig.json",
  "include": ["vite.config.*"],
  "compilerOptions": {
    "composite": true,
    "types": ["node", "vitest"],
    // allow importing JSON files like package.json from TS modules
    "resolveJsonModule": true,
    // enable interoperability when importing CommonJS defaults (pkg)
    "esModuleInterop": true
  }
}
